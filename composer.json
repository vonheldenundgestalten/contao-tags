{
  "name":"vonheldenundgestalten/contao-tags",
  "description":"tags is a Contao extension that provides an architecture to tag any Contao element.",
  "keywords":["contao", "module", "extension", "tagcloud", "tags"],
  "type":"contao-bundle",
  "license":["LGPL-3.0-or-later", "CC-BY-NC-SA-4.0"],
  "authors":[
    {
      "name":"Helmut Schottmüller",
      "homepage":"https://github.com/hschottm"
    },
    {
      "name": "Filip Secic",
      "role": "Developer",
      "homepage":"https://github.com/FilipSec"
    }
  ],
  "require":{
    "php": "^8.0",
    "contao/core-bundle": "^5.3",
    "contao/manager-plugin": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "VHUG\\ContaoTags\\": "src/"
    },
    "classmap": [
      "classes/",
      "elements/",
      "models/",
      "modules/"
    ]
  },
  "extra": {
    "contao-manager-plugin": "VHUG\\ContaoTags\\ContaoManager\\Plugin"
  }
}
